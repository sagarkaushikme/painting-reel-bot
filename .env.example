# ============================================================
# Painting Reel Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Gemini API (free at aistudio.google.com → Get API Key)
# Free tier: 250 requests/day — more than enough for 1 daily run
GEMINI_API_KEY=your_gemini_api_key_here

# Instagram Graph API
# Setup: developers.facebook.com/docs/instagram-api
# You need a Business/Creator Instagram account linked to a Facebook Page
# Generate a long-lived token (valid 60 days, must refresh manually)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# GitHub (for hosting video as GitHub Release asset — free public URL)
# Create a Personal Access Token with 'repo' scope
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=yourusername/painting-reel-bot

# ============================================================
# NOTE: Rijksmuseum API key is NOT needed anymore.
# The new Rijksmuseum Data Services API (data.rijksmuseum.nl)
# is completely free and requires no authentication.
# Met Museum API also requires no key.
# ============================================================
