# ============================================================
# Content Automation System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Gemini API (free at aistudio.google.com → Get API Key)
# Free tier: 250 requests/day — more than enough for daily runs
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub (for hosting video as GitHub Release asset — free public URL)
# Create a Personal Access Token with 'repo' scope
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=yourusername/content-automation-system

# ============================================================
# PAGE: painting_explained
# ============================================================

# Instagram Graph API for Painting Explained page
PAINTING_IG_TOKEN=your_painting_ig_long_lived_token_here
PAINTING_IG_USER_ID=your_painting_ig_user_id_here

# ============================================================
# PAGE: paisa_ka_gyaan
# ============================================================

# Instagram Graph API for Paisa Ka Gyaan page
PAISA_IG_TOKEN=your_paisa_ig_long_lived_token_here
PAISA_IG_USER_ID=your_paisa_ig_user_id_here

# ============================================================
# NOTES:
# - Rijksmuseum API key is NOT needed (free public API)
# - Met Museum API requires no key
# - Each page has its own IG credentials
# - Add new pages by creating pages/<page_id>/ folder
# ============================================================
